type Point
  x: byte
  y: byte
  color: word
end

union Payload
  asByte: byte
  asWord: word
end

type Node
  tag: byte
  payload: Payload
end

type Scene
  header: word
  sprites: Point[4]
end

const OffY = offset(Point, y)
const Idx = 3
const OffSpritesIdxColor = offset(Scene, sprites[Idx].color)
const OffPayloadWord = offset(Node, payload.asWord)

export func main()
  ld a, OffY
  ld hl, OffSpritesIdxColor
  ld de, OffPayloadWord
end
