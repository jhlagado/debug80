{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [["[", "]"]],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*begin\\s*(?:;.*)?$",
      "end": "^\\s*end\\s*$"
    }
  }
}
