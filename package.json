{
  "name": "debug80",
  "displayName": "Z80 Debugger",
  "description": "Debug Adapter for Z80 programs (asm80 + HEX/LST)",
  "version": "0.0.1",
  "publisher": "jhlagado",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhlagado/debug80.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:z80",
    "workspaceContains:**/debug80.json",
    "workspaceContains:**/.vscode/debug80.json",
    "onLanguage:asm",
    "onLanguage:asm-collection",
    "onLanguage:zax",
    "onLanguage:z80-asm",
    "onLanguage:z80-macroasm"
  ],
  "extensionPack": [
    "imanolea.z80-asm"
  ],
  "main": "./out/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySideBar": [
        {
          "id": "debug80",
          "title": "Debug80",
          "icon": "assets/debug80-icon.svg"
        }
      ]
    },
    "views": {
      "debug80": [
        {
          "type": "webview",
          "id": "debug80.platformView",
          "name": "Platform"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "debug80.platformView",
        "contents": "No Debug80 project found in this workspace.\n[Create Project](command:debug80.createProject)\nCreate a debug80.json configuration file to get started.",
        "when": "!debug80.hasProject"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.asm": "z80-asm",
        "*.z80": "z80-asm",
        "*.a80": "z80-asm",
        "*.s": "z80-asm",
        "*.zax": "zax"
      }
    },
    "languages": [
      {
        "id": "z80-asm",
        "aliases": [
          "Z80 Assembly"
        ],
        "extensions": [
          ".asm",
          ".z80",
          ".a80",
          ".s"
        ]
      },
      {
        "id": "z80-lst",
        "aliases": [
          "Z80 Listing"
        ],
        "extensions": [
          ".lst"
        ],
        "configuration": "./out/null-language.json"
      },
      {
        "id": "zax",
        "aliases": [
          "ZAX"
        ],
        "extensions": [
          ".zax"
        ],
        "configuration": "./out/null-language.json"
      }
    ],
    "grammars": [
      {
        "language": "z80-lst",
        "scopeName": "source.z80.lst",
        "path": "./syntaxes/z80-lst.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "z80-lst"
      },
      {
        "language": "asm-collection"
      },
      {
        "language": "asm-list-file"
      },
      {
        "language": "z80-asm"
      },
      {
        "language": "z80-macroasm"
      },
      {
        "language": "wla-dx-asm"
      },
      {
        "language": "asm"
      },
      {
        "language": "asm80"
      },
      {
        "language": "z80"
      },
      {
        "language": "zax"
      }
    ],
    "commands": [
      {
        "command": "debug80.createProject",
        "title": "Debug80: Create Project"
      },
      {
        "command": "debug80.startDebug",
        "title": "Debug80: Start Debugging"
      },
      {
        "command": "debug80.terminalInput",
        "title": "Debug80: Send Terminal Input"
      },
      {
        "command": "debug80.openTerminal",
        "title": "Debug80: Show Terminal Panel"
      },
      {
        "command": "debug80.openTec1",
        "title": "Debug80: Show TEC-1 Panel"
      },
      {
        "command": "debug80.openTec1Memory",
        "title": "Debug80: Show TEC-1 Memory Panel"
      },
      {
        "command": "debug80.selectWorkspaceFolder",
        "title": "Debug80: Select Workspace Folder"
      },
      {
        "command": "debug80.selectTarget",
        "title": "Debug80: Select Active Target"
      },
      {
        "command": "debug80.restartDebug",
        "title": "Debug80: Restart Debugging (Current Target)"
      },
      {
        "command": "debug80.setEntrySource",
        "title": "Debug80: Set Program File"
      },
      {
        "command": "debug80.configureProject",
        "title": "Debug80: Configure Project"
      },
      {
        "command": "debug80.openRomSource",
        "title": "Debug80: Open ROM Listing/Source"
      },
      {
        "command": "debug80.openProjectConfigPanel",
        "title": "Debug80: Open Project Configuration Panel"
      },
      {
        "command": "debug80.materializeBundledRom",
        "title": "Debug80: Copy Bundled MON3 ROM and Listing into Workspace"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "debug80.setEntrySource",
          "when": "resourceExtname == .asm || resourceExtname == .zax",
          "group": "navigation@9"
        }
      ],
      "editor/context": [
        {
          "command": "debug80.setEntrySource",
          "when": "resourceExtname == .asm || resourceExtname == .zax",
          "group": "navigation@9"
        }
      ],
      "editor/title/context": [
        {
          "command": "debug80.setEntrySource",
          "when": "resourceExtname == .asm || resourceExtname == .zax",
          "group": "navigation@9"
        }
      ]
    },
    "debuggers": [
      {
        "type": "z80",
        "label": "Z80 Debug",
        "languages": [
          "asm-collection",
          "asm-list-file",
          "z80-asm",
          "z80-macroasm",
          "wla-dx-asm",
          "asm",
          "asm80",
          "z80",
          "z80-lst",
          "zax"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "projectConfig": {
                "type": "string",
                "description": "Path to debug80 project config (defaults to ${workspaceFolder}/debug80.json)"
              },
              "target": {
                "type": "string",
                "description": "Target name from the project config (defaults to defaultTarget)"
              },
              "asm": {
                "type": "string",
                "description": "Root assembly source file"
              },
              "assembler": {
                "type": "string",
                "description": "Assembler backend to use (default: asm80)",
                "enum": [
                  "asm80",
                  "zax"
                ],
                "default": "asm80"
              },
              "outputDir": {
                "type": "string",
                "description": "Directory for generated hex/lst artifacts (defaults to asm directory)"
              },
              "artifactBase": {
                "type": "string",
                "description": "Base filename for generated hex/lst (defaults to asm basename)"
              },
              "hex": {
                "type": "string",
                "description": "Path to a Z80 Intel HEX file (optional if asm is provided)"
              },
              "listing": {
                "type": "string",
                "description": "Path to a Z80 .lst listing file for source mapping (optional if asm is provided)"
              },
              "entry": {
                "type": "number",
                "description": "Override entry point (defaults to start of HEX data)"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop on the first instruction",
                "default": true
              },
              "openRomSourcesOnLaunch": {
                "type": "boolean",
                "description": "Open ROM listing/source files automatically on launch",
                "default": true
              },
              "openMainSourceOnLaunch": {
                "type": "boolean",
                "description": "Open the primary source file automatically on launch",
                "default": true
              },
              "sourceColumn": {
                "type": "number",
                "description": "Editor column (1-9) for source files opened on launch",
                "default": 1
              },
              "panelColumn": {
                "type": "number",
                "description": "Editor column (1-9) for Debug80 platform panels",
                "default": 2
              },
              "assemble": {
                "type": "boolean",
                "description": "Run the assembler before launch when asm is provided",
                "default": true
              },
              "sourceRoots": {
                "type": "array",
                "description": "Additional directories to resolve source file paths from LST anchors",
                "items": {
                  "type": "string"
                }
              },
              "stepOverMaxInstructions": {
                "type": "number",
                "description": "Maximum instructions to execute during Step Over before stopping (0 disables the cap)."
              },
              "stepOutMaxInstructions": {
                "type": "number",
                "description": "Maximum instructions to execute during Step Out before stopping (0 disables the cap)."
              },
              "terminal": {
                "type": "object",
                "description": "Optional terminal device port mapping",
                "properties": {
                  "txPort": {
                    "type": "number",
                    "description": "OUT port for transmit bytes"
                  },
                  "rxPort": {
                    "type": "number",
                    "description": "IN port for receive bytes"
                  },
                  "statusPort": {
                    "type": "number",
                    "description": "IN port for status bits (bit0 RX avail, bit1 TX ready)"
                  },
                  "interrupt": {
                    "type": "boolean",
                    "description": "Future: raise interrupt on RX available",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "z80",
            "request": "launch",
            "name": "Debug80: Current Project",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "Debug80: Current Project",
            "description": "Launch the selected Debug80 project and target from the current workspace",
            "body": {
              "type": "z80",
              "request": "launch",
              "name": "Debug80: Current Project",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "keybindings": [
      {
        "command": "debug80.startDebug",
        "key": "f5",
        "when": "debug80.hasProject && !inDebugMode"
      }
    ]
  },
  "scripts": {
    "build": "tsc && npm run build:webview",
    "bundle:sync-mon3": "node scripts/sync-mon3-bundle.cjs",
    "build:webview": "node scripts/build-webview.js",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "typecheck:webview": "tsc -p webview/tsconfig.json --noEmit",
    "watch": "tsc --watch",
    "lint": "eslint src tests webview --ext .ts",
    "lint:fix": "eslint src tests webview --ext .ts --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "pretest": "npm run build",
    "test": "vitest run && npm run test:webview",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "perf:z80": "npm run build && node scripts/perf-z80.js",
    "package": "vsce package",
    "test:webview": "vitest run -c vitest.webview.config.ts",
    "test:e2e:adapter": "vitest run -c vitest.e2e.config.ts",
    "test:e2e": "npm run test:e2e:adapter"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --cache --fix --max-warnings=0"
    ],
    "tests/**/*.ts": [
      "eslint --cache --fix --max-warnings=0"
    ],
    "webview/**/*.ts": [
      "eslint --cache --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "0.33.0",
    "@vscode/vsce": "^2.22.0",
    "ajv": "^8.18.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.55.0",
    "eslint-plugin-jsdoc": "^48.2.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.1.0",
    "typescript": "5.3.3",
    "vitest": "0.33.0"
  },
  "dependencies": {
    "@jhlagado/zax": "^0.2.2",
    "@vscode/debugadapter": "^1.64.0",
    "@vscode/debugprotocol": "^1.64.0",
    "asm80": "^1.11.14"
  }
}
